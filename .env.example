# Agent Control environment template
# Copy to .env. Never commit real values.

# Core security
# Generated by setup when .env is created. Required for HTTP/WS auth in shared networks.
AGENT_TOKEN=

# Engine profiles
# CLI/OAuth profiles can work without API keys when the CLI is signed in.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Optional model providers
GROQ_API_KEY=
MOONSHOT_API_KEY=

# Search and research
BRAVE_API_KEY=

# Local model providers
LOCAL_LLM_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=
OLLAMA_MODEL=

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
VOICE_INPUT_DISCORD_TOKEN=
VOICE_TRANSCRIPT_MODE=single

# Optional mail module
RESEND_API_KEY=
DENZER_RESEND_API_KEY=

# Optional WhatsApp module
WA_BRIDGE_URL=http://127.0.0.1:8891

# Optional PT module
PTDESK_BASE_URL=https://ptdesk.app/functions
PTDESK_API_KEY=
PTDESK_TRAINER_EMAIL=

# Optional finance/content modules
COINMARKETCAP_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_NAME=

# Optional local pane input
# Generate like AGENT_TOKEN. Empty disables the endpoint.
KLAUSFLOW_PANE_TOKEN=
